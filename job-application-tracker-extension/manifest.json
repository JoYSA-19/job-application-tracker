{
  "manifest_version": 3,
  "name": "Job Application Tracker",
  "version": "1.0",
  "description": "Save job applications to your Google Sheet",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Job Application Tracker",
    "default_icon": {
      "16": "icons/icon_default_16.png",
      "32": "icons/icon_default_32.png",
      "48": "icons/icon_default_48.png",
      "128": "icons/icon_default_128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon_default_16.png",
    "32": "icons/icon_default_32.png",
    "48": "icons/icon_default_48.png",
    "128": "icons/icon_default_128.png"
  }
}